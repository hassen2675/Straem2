<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg">

    <!-- Logo top center -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_centerHorizontal="true" android:layout_marginTop="28dp"
        android:orientation="vertical" android:gravity="center"
        android:id="@+id/llLogo">
        <ImageView android:layout_width="64dp" android:layout_height="64dp"
            android:src="@drawable/ic_logo" android:layout_marginBottom="6dp"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Stream" android:textColor="#6C63FF"
                android:textSize="28sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Vision" android:textColor="#FFFFFF"
                android:textSize="28sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- User + expiry info top right -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_alignParentEnd="true" android:layout_marginTop="18dp"
        android:layout_marginEnd="20dp" android:orientation="vertical" android:gravity="end">
        <TextView android:id="@+id/tvUser" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#8892B0" android:textSize="13sp"/>
        <TextView android:id="@+id/tvExpiry" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#3D4466" android:textSize="11sp"/>
    </LinearLayout>

    <!-- Tiles grid centered -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:paddingStart="40dp" android:paddingEnd="40dp">

        <!-- Row 1: Live (big) + Movies + Series -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">

            <!-- Live TV - big -->
            <LinearLayout android:id="@+id/tileLive"
                android:layout_width="0dp" android:layout_height="170dp"
                android:layout_weight="2.2" android:orientation="vertical"
                android:gravity="center" android:background="@drawable/tile_live"
                android:layout_marginEnd="10dp" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📡" android:textSize="44sp" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Live Fernsehen" android:textColor="#FFFFFF"
                    android:textSize="16sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Right column -->
            <LinearLayout android:layout_width="0dp" android:layout_height="170dp"
                android:layout_weight="1.8" android:orientation="vertical">

                <!-- Movies -->
                <LinearLayout android:id="@+id/tileMovies"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/tile_movies"
                    android:layout_marginBottom="6dp"
                    android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎬" android:textSize="28sp" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Filme" android:textColor="#FFFFFF"
                        android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Series -->
                <LinearLayout android:id="@+id/tileSeries"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/tile_series"
                    android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎭" android:textSize="28sp" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Serien" android:textColor="#FFFFFF"
                        android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Settings, Reload, Exit -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout android:id="@+id/tileSettings"
                android:layout_width="0dp" android:layout_height="80dp"
                android:layout_weight="1" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingStart="18dp"
                android:background="@drawable/tile_dark"
                android:layout_marginEnd="10dp" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚙️" android:textSize="22sp" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Einstellungen" android:textColor="#FFFFFF"
                    android:textSize="13sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/tileAccount"
                android:layout_width="0dp" android:layout_height="80dp"
                android:layout_weight="1" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingStart="18dp"
                android:background="@drawable/tile_dark"
                android:layout_marginEnd="10dp" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👤" android:textSize="22sp" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Account" android:textColor="#FFFFFF"
                    android:textSize="13sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/tileExit"
                android:layout_width="0dp" android:layout_height="80dp"
                android:layout_weight="1" android:orientation="horizontal"
                android:gravity="center_vertical" android:paddingStart="18dp"
                android:background="@drawable/tile_dark"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🚪" android:textSize="22sp" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Beenden" android:textColor="#FFFFFF"
                    android:textSize="13sp" android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Version bottom right -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" android:layout_alignParentEnd="true"
        android:layout_margin="12dp" android:text="v1.0"
        android:textColor="#3D4466" android:textSize="11sp"/>

</RelativeLayout>
