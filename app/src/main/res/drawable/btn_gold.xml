<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="#B8960C" android:endColor="#8B6914" android:angle="135"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="#FFD700" android:endColor="#FFA500" android:angle="135"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
</selector>
